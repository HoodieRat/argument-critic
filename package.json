{
  "name": "argument-critic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "app:setup": "tsx scripts/install.ts",
    "start": "tsx scripts/start.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "build": "corepack pnpm --filter @argument-critic/desktop build && corepack pnpm --filter @argument-critic/server build",
    "build:legacy-extension": "corepack pnpm --filter @argument-critic/extension build",
    "test": "corepack pnpm --filter @argument-critic/server test"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}